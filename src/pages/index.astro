---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavHeader from '../components/NavHeader.astro';
import HeroSection from '../components/HeroSection.astro';
import MarqueeBand from '../components/MarqueeBand.astro';
import AboutSection from '../components/AboutSection.astro';
import CateringSection from '../components/CateringSection.astro';
import DoggieMacsSection from '../components/DoggieMacsSection.astro';
import SoulcialSection from '../components/SoulcialSection.astro';
import GallerySection from '../components/GallerySection.astro';
import ReviewsSection from '../components/ReviewsSection.astro';
import LeadSection from '../components/LeadSection.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';
import { BUSINESS } from '../config/business';

const pageTitle = `${BUSINESS.name} — Catering & Doggie Macs Food Truck · Swansea, IL`;
---

<BaseLayout title={pageTitle}>
  <NavHeader />
  <main id="top">
    <HeroSection />
    <MarqueeBand />
    <AboutSection />
    <CateringSection />
    <DoggieMacsSection />
    <SoulcialSection />
    <GallerySection />
    <ReviewsSection />
    <LeadSection />
    <FAQSection />
  </main>
  <Footer />
</BaseLayout>
