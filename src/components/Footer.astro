---
import { BUSINESS } from '../config/business';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Col 1: Brand + social -->
      <div class="footer-col footer-col--brand">
        <div class="footer-brand">{BUSINESS.name}</div>
        <p class="footer-brand-sub">{BUSINESS.tagline}</p>
        <div class="socials">
          {BUSINESS.social.instagram && (
            <a href={BUSINESS.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.75" fill="currentColor" stroke="none"/>
              </svg>
            </a>
          )}
          {BUSINESS.social.tiktok && (
            <a href={BUSINESS.social.tiktok} target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.15 8.15 0 0 0 4.77 1.52V6.76a4.85 4.85 0 0 1-1-.07z"/>
              </svg>
            </a>
          )}
          {BUSINESS.social.facebook && (
            <a href={BUSINESS.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- Col 2: Explore nav -->
      <div class="footer-col">
        <h5>Explore</h5>
        <ul>
          <li><a href="#about">About Chef B</a></li>
          <li><a href="#catering">Catering</a></li>
          <li><a href="#doggie-macs">Doggie Macs</a></li>
          <li><a href="#soulcial">Soulcial Kitchen</a></li>
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#lead">Book Now</a></li>
        </ul>
      </div>

      <!-- Col 3: Visit -->
      <div class="footer-col">
        <h5>Visit</h5>
        <address class="footer-address">
          <p>{BUSINESS.streetAddress}</p>
          <p>{BUSINESS.addressLocality}, {BUSINESS.addressRegion} {BUSINESS.postalCode}</p>
        </address>
        <div class="footer-hours">
          {BUSINESS.hours.map(h => (
            <div class="footer-hours-row">
              <span>{h.days}</span>
              <span>{h.hours}</span>
            </div>
          ))}
        </div>
        {BUSINESS.social.googleBusinessProfile && (
          <a href={BUSINESS.social.googleBusinessProfile} class="footer-map-link" target="_blank" rel="noopener noreferrer">
            View on Google Maps →
          </a>
        )}
      </div>

      <!-- Col 4: Contact -->
      <div class="footer-col">
        <h5>Contact</h5>
        <ul>
          <li>
            <a href={`tel:${BUSINESS.phone.replace(/\D/g, '')}`}>{BUSINESS.phone}</a>
          </li>
          <li>
            <a href={`mailto:${BUSINESS.email}`}>{BUSINESS.email}</a>
          </li>
        </ul>
        <a href="#lead" class="btn btn-primary" style="margin-top: 24px; display: inline-flex;">Book Catering →</a>
      </div>

    </div>
  </div>

  <div class="footer-bottom">
    <div class="container">
      <div class="footer-bottom-inner">
        <span>© <span id="footer-year"></span> {BUSINESS.name}. All rights reserved.</span>
        <span>SWANSEA · BELLEVILLE · O'FALLON · ST. LOUIS</span>
      </div>
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
