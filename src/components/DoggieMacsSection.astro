---
import { Image } from 'astro:assets';
import { BUSINESS } from '../config/business';
---

<section class="doggie" id="doggie">
  <div class="container">

    <!-- ── Section intro ───────────────────────────── -->
    <div class="doggie-hero">
      <h2>Doggie<br />Macs<br /><em>— the food truck.</em></h2>
      <div class="meta">
        <p>The mac-forward, mood-lifting little brother of the catering side. Permanently parked at Soulcial Kitchen — pull up, eat well, leave full.</p>
        <a href="#soulcial" class="btn btn-primary">Get directions <span aria-hidden="true">→</span></a>
      </div>
    </div>

    <!-- ── Info cards ───────────────────────────────── -->
    <div class="doggie-stack">

      <!-- Location + hours -->
      <div class="truck-card">
        <span class="label">// PERMANENT LOCATION</span>
        <div class="big">
          {BUSINESS.streetAddress}<br />
          {BUSINESS.addressLocality}, {BUSINESS.addressRegion} {BUSINESS.postalCode}
        </div>
        <div class="small">Parked outside Soulcial Kitchen, all year round.</div>

        <div id="openStatus" class="open-now" aria-live="polite"></div>

        <div class="hours">
          <div class="hour-row closed"><span class="day">Mon</span><span>Closed</span></div>
          <div class="hour-row closed"><span class="day">Tue</span><span>Closed</span></div>
          <div class="hour-row closed"><span class="day">Wed</span><span>Closed</span></div>
          <div class="hour-row"><span class="day">Thu</span><span>11–2 · 5–9</span></div>
          <div class="hour-row"><span class="day">Fri</span><span>11–2 · 5–9</span></div>
          <div class="hour-row"><span class="day">Sat</span><span>11–2 · 5–9</span></div>
          <div class="hour-row closed"><span class="day">Sun</span><span>Closed</span></div>
        </div>

        <p class="truck-note">
          The truck is <strong>not available</strong> for off-site events or private parties —
          for off-site catering, see our <a href="#catering">catering menu</a>.
        </p>
      </div>

      <!-- Phone + socials -->
      <div class="truck-card truck-card--split">
        <div>
          <span class="label">// CALL AHEAD</span>
          <div class="big" style="font-size:clamp(24px,3vw,32px)">
            <a href={`tel:${BUSINESS.phone.replace(/\D/g, '')}`}>{BUSINESS.phone}</a>
          </div>
          <div class="small">Large orders, party trays, and group pickups — give us a heads up.</div>
        </div>
        <div>
          <span class="label">// FOLLOW THE TRUCK</span>
          <div style="display:flex;gap:10px;margin-top:12px">
            {BUSINESS.social.instagram && (
              <a href={BUSINESS.social.instagram} target="_blank" rel="noopener" class="social-btn" aria-label="Instagram">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              </a>
            )}
            {BUSINESS.social.tiktok && (
              <a href={BUSINESS.social.tiktok} target="_blank" rel="noopener" class="social-btn" aria-label="TikTok">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.29 6.29 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.17 8.17 0 0 0 4.77 1.52V6.77a4.85 4.85 0 0 1-1-.08z"/></svg>
              </a>
            )}
            {BUSINESS.social.facebook && (
              <a href={BUSINESS.social.facebook} target="_blank" rel="noopener" class="social-btn" aria-label="Facebook">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
            )}
          </div>
        </div>
      </div>

    </div>

    <!-- ── Menu item cards ──────────────────────────── -->
    <div class="dogs-grid">

      <div class="dog-card">
        <div class="img">
          <span class="tag">★ Most ordered</span>
          <Image
            src="/assets/jerk-pork-mac.png"
            alt="Jerk Pork Mac — Grandma's mac and cheese topped with slow-braised jerk pork, pico, and candied sauce drizzle"
            width={480}
            height={440}
          />
        </div>
        <div class="body">
          <h4>Jerk Pork Mac</h4>
          <p>Grandma's mac &amp; cheese, slow-braised jerk pork, pico, candied sauce drizzle.</p>
          <div class="row">
            <span class="eyebrow">/ 12 oz bowl</span>
            <span class="price">$14</span>
          </div>
        </div>
      </div>

      <div class="dog-card">
        <div class="img">
          <span class="tag">Truck classic</span>
          <Image
            src="/assets/chicago-dog.png"
            alt="Chicago-style hot dog — all-beef dog with mustard, neon relish, sport peppers, tomato, pickle, and celery salt on a poppy seed bun"
            width={480}
            height={440}
          />
        </div>
        <div class="body">
          <h4>Chicago Dog</h4>
          <p>All-beef dog, mustard, neon relish, sport peppers, tomato, pickle, celery salt.</p>
          <div class="row">
            <span class="eyebrow">/ on a poppy bun</span>
            <span class="price">$8</span>
          </div>
        </div>
      </div>

      <div class="dog-card">
        <div class="img">
          <span class="tag">Sharable</span>
          <Image
            src="/assets/loaded-nachos.png"
            alt="Loaded Nachos — house queso, pico, jalapeño, sour cream, and choice of protein"
            width={480}
            height={440}
          />
        </div>
        <div class="body">
          <h4>Loaded Nachos</h4>
          <p>House queso, pico, jalapeño, sour cream, your pick of protein on top.</p>
          <div class="row">
            <span class="eyebrow">/ feeds 2</span>
            <span class="price">$13</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  (function () {
    const badge = document.getElementById('openStatus');
    if (!badge) return;

    // Resolve current moment in America/Chicago (Central) timezone
    const parts = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Chicago',
      weekday: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    }).formatToParts(new Date());

    const get = (type: string) => parts.find((p) => p.type === type)?.value ?? '0';
    const day  = get('weekday');
    const h    = parseInt(get('hour'),   10);
    const min  = parseInt(get('minute'), 10);
    const t    = h * 60 + min;

    // Thu=4, Fri=5, Sat=6 — 11:00–14:00 (660–839) and 17:00–21:00 (1020–1259)
    const isOpenDay  = new Set(['Thu', 'Fri', 'Sat']).has(day);
    const isOpenTime = (t >= 660 && t < 840) || (t >= 1020 && t < 1260);
    const isOpen     = isOpenDay && isOpenTime;

    badge.textContent = isOpen ? '● Open now' : '○ Closed';
    badge.classList.add(isOpen ? 'is-open' : 'is-closed');
  })();
</script>
